/* Chlorophyll — Rofi color definitions
 * Rendered output goes to ~/.cache/chlorophyll/colors-rofi.rasi
 *
 * Import from your rofi config:
 *   @import "~/.cache/chlorophyll/colors-rofi.rasi"
 */

* {
    color0: {{color0}};
    color1: {{color1}};
    color2: {{color2}};
    color3: {{color3}};
    color4: {{color4}};
    color5: {{color5}};
    color6: {{color6}};
    color7: {{color7}};

    background: @color0;
    foreground: @color7;
}
